{
  "name": "@sapirrior/codefile",
  "version": "1.0.0",
  "description": "Pack a project directory into a single structured text file for LLM context.",
  "keywords": [
    "cli",
    "bundle",
    "llm",
    "context",
    "typescript"
  ],
  "type": "module",
  "bin": {
    "codefile": "./build/cli.js"
  },
  "main": "./build/cli.js",
  "exports": {
    ".": "./build/cli.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test tests/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sapirrior/codefile-node.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^25.5.0"
  }
}
